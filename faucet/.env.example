# reCAPTCHA 解码服务 API Key（二选一）
# 2Captcha: https://2captcha.com/
TWOCAPTCHA_API_KEY=your_2captcha_api_key_here
# CapSolver: https://www.capsolver.com/
CAPSOLVER_API_KEY=your_capsolver_api_key_here

# 使用哪个验证码服务: "2captcha" 或 "capsolver"
CAPTCHA_SERVICE=2captcha

# 钱包地址（多个用逗号分隔）
WALLET_ADDRESSES=0xYourAddress1,0xYourAddress2

# Google 账号 Cookie（从浏览器 DevTools Network 复制）
# 需要完整的 cookie 字符串
GOOGLE_COOKIES="YOUR_GOOGLE_COOKIES_HERE"
